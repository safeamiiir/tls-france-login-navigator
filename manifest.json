{
  "manifest_version": 3,
  "name": "TLS France Login Navigator",
  "version": "1.1.0",
  "description": "Navigates you straight to the France (UK/London) TLScontact booking appointment slots and auto-refreshes the page while you wait.",
  "author": "safeamiiir",
  "homepage_url": "https://github.com/safeamiiir/tls-france-login-navigator",
  "permissions": [
    "scripting",
    "activeTab",
    "tabs",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "https://visas-fr.tlscontact.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TLS France Navigator"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
